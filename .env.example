# GitHub Personal Access Token
# Required for API access - get from https://github.com/settings/tokens
GITHUB_PAT=ghp_your_github_personal_access_token_here

# Optional: AWS credentials for S3 access (if using S3 features)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=us-east-1

# Optional: Pipeline configuration
# GITHUB_SEARCH_TERM="cardano wallet"
# MAX_REPOSITORIES=500
# MIN_STARS=0

# Optional: Database configuration
# DATABASE_FILE=github_cardano.duckdb
# DATASET_NAME=github_data

# Optional: Logging configuration
# LOG_LEVEL=INFO
# LOG_FILE=logs/pipeline.log